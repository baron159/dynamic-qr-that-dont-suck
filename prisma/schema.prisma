// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
  runtime    = "cloudflare"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String  @id @default(cuid(2))
  email               String  @unique
  passHash            String
  name                String
  phone               String?
  stripeCustomerId    String?
  monthlySubscription String? // Users can have
  Qr                  Qr[]
  Credit              Credit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Qr {
  id               String   @id @default(uuid(7))
  kvId             String @unique
  nickname String @default("QR Dynamics")
  active           Boolean  @default(true)
  redirectLink     String
  scanCount        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  User   User   @relation(fields: [userId], references: [id])
  Credit Credit? @relation(fields: [creditId], references: [id])
  userId String
  creditId String? // Optional because a subscription QR doesn't have a credit
}

// Credits are one-time purchased credits that can be used to create QR codes
model Credit {
  id String @id @default(uuid(7))
  userId String
  shopifyOrderId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // This can be removed... it will never be modified

  User User @relation(fields: [userId], references: [id])
  Qr Qr[]
}
